<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E6E6E6">

    <!-- Top Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topAppBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#420303"
        android:theme="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar"
        app:title="Select Payment Option"
        app:navigationIcon="@android:drawable/ic_menu_revert"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Container for buttons -->
    <LinearLayout
        android:id="@+id/buttonContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- School Fees -->
        <Button
            android:id="@+id/btnFees"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:text="School Fees"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#49040A"
            android:layout_marginBottom="16dp"/>

        <!-- Food -->
        <Button
            android:id="@+id/btnFood"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:text="Food"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#49040A"
            android:layout_marginBottom="16dp"/>

        <!-- Transport -->
        <Button
            android:id="@+id/btnTransport"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:text="Transport"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#49040A"
            android:layout_marginBottom="16dp"/>

        <!-- Other -->
        <Button
            android:id="@+id/btnOther"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:text="Other Payments"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#49040A"/>

        <Button
            android:id="@+id/btnhistory"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:text="View Payment History"
            android:textSize="20sp"
            android:textColor="#fffc67"
            android:backgroundTint="#080649"/>

        <Button
            android:id="@+id/btnreceipts"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:text="View Receipts"
            android:textSize="20sp"
            android:textColor="#fffc67"
            android:backgroundTint="#080649" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>